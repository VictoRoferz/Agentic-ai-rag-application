# ============================================================
# Syte Knowledge Assistant - Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to git!
# ============================================================

# Anthropic (Claude) API Key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: OpenAI API Key (for OpenAI-compatible local servers)
# OPENAI_API_KEY=sk-your-key-here

# Optional: Cohere API Key (for Cohere Rerank as alternative)
# COHERE_API_KEY=your-key-here

# Qdrant (only needed for Qdrant Cloud, not local Docker)
# QDRANT_API_KEY=your-key-here
# QDRANT_URL=https://your-cluster.qdrant.tech
